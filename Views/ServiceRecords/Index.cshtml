@model IEnumerable<CarServiceTracker.Models.ServiceRecord>

@{
    ViewData["Title"] = "Service Records";
}

<h1>Service Records</h1>

@if (ViewBag.FilterCar != null)
{
    <div class="alert alert-info">
        Showing records for: <strong>@ViewBag.FilterCar</strong>
        <a asp-action="Index" class="ms-2">Show all</a>
    </div>
}

<p>
    <a class="btn btn-primary" asp-action="Create">Create New</a>
</p>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Date</th>
            <th>Car</th>
            <th>Service Type</th>
            <th>Mileage</th>
            <th>Price</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Date.ToString("yyyy-MM-dd")</td>
                <td>@(item.Car != null ? $"{item.Car.Brand} {item.Car.Model}" : item.CarId.ToString())</td>
                <td>@(item.ServiceType != null ? item.ServiceType.Name : item.ServiceTypeId.ToString())</td>
                <td>@item.Mileage</td>
                <td class="fw-semibold text-success">€@item.Price.ToString("F2")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                    @if (User.IsInRole("Administrator"))
                    {
                        @: |
                        <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if ((int)ViewBag.TotalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == (int)ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-carId="@ViewBag.CurrentCarId">
                        @i
                    </a>
                </li>
            }
        </ul>
    </nav>
}