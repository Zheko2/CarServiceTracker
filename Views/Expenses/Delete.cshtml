@model CarServiceTracker.Models.Expense

@{
    ViewData["Title"] = "Delete Expense";
}

<h2>Delete Expense</h2>

<h4 class="text-danger">Are you sure you want to delete this?</h4>

<dl class="row">
    <dt class="col-sm-2">Title</dt>
    <dd class="col-sm-10">@Model.Title</dd>

    <dt class="col-sm-2">Amount</dt>
    <dd class="col-sm-10 text-success fw-semibold">€@Model.Amount.ToString("F2")</dd>

    <dt class="col-sm-2">Date</dt>
    <dd class="col-sm-10">@Model.Date.ToString("yyyy-MM-dd")</dd>

    <dt class="col-sm-2">Car</dt>
    <dd class="col-sm-10">@Model.Car?.Brand @Model.Car?.Model</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>