@model CarServiceTracker.Models.Garage

@{
    ViewData["Title"] = "Delete Garage";
}

<h2>Delete Garage</h2>

<h4 class="text-danger">Are you sure you want to delete this?</h4>

<hr />

<dl class="row">
    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">Location</dt>
    <dd class="col-sm-10">@Model.Location</dd>

    <dt class="col-sm-2">Cars</dt>
    <dd class="col-sm-10">@(Model.Cars?.Count ?? 0)</dd>
</dl>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>