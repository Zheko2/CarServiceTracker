@model CarServiceTracker.Models.Garage

@{
    ViewData["Title"] = "Garage Details";
}

<h2>Garage Details</h2>

<div class="mb-4">
    <p><strong>Name:</strong> @Model.Name</p>
    <p><strong>Location:</strong> @Model.Location</p>
    <p><strong>Cars:</strong> @(Model.Cars?.Count ?? 0)</p>
</div>

@if (Model.Cars != null && Model.Cars.Any())
{
    <h4>Cars in this garage</h4>

    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Brand</th>
                <th>Model</th>
                <th>Year</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var car in Model.Cars.OrderBy(c => c.Brand).ThenBy(c => c.Model))
            {
                <tr>
                    <td>@car.Brand</td>
                    <td>@car.Model</td>
                    <td>@car.Year</td>
                    <td>@car.Status</td>
                    <td>
                        <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id">View Car</a> |
                        <a asp-controller="Cars" asp-action="Edit" asp-route-id="@car.Id">Change Status</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        No cars are currently assigned to this garage.
    </div>
}

<a asp-action="Index" class="btn btn-secondary">Back</a>