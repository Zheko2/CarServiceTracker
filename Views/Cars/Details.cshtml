@model CarServiceTracker.Models.Car

@{
	ViewData["Title"] = "Car Details";
}

<h2>Car Details</h2>

<div class="card shadow-sm">
	<div class="card-body bg-white text-dark">
		<dl class="row mb-0">
			<dt class="col-sm-3">Brand</dt>
			<dd class="col-sm-9">@Model.Brand</dd>

			<dt class="col-sm-3">Model</dt>
			<dd class="col-sm-9">@Model.Model</dd>

			<dt class="col-sm-3">Year</dt>
			<dd class="col-sm-9">@Model.Year</dd>

			<dt class="col-sm-3">Status</dt>
			<dd class="col-sm-9">@Model.Status</dd>

			<dt class="col-sm-3">Garage</dt>
			<dd class="col-sm-9">
				@(Model.Garage != null ? $"{Model.Garage.Name} - {Model.Garage.Location}" : "No garage assigned")
			</dd>

			<dt class="col-sm-3">Service Records</dt>
			<dd class="col-sm-9">@(Model.ServiceRecords?.Count ?? 0)</dd>

			<dt class="col-sm-3">Expenses</dt>
			<dd class="col-sm-9">@(Model.Expenses?.Count ?? 0)</dd>

			@if (User.IsInRole("Administrator"))
			{
				<dt class="col-sm-3">Owner</dt>
				<dd class="col-sm-9">
					@(Model.Owner != null ? Model.Owner.Email : Model.OwnerId)
				</dd>
			}
		</dl>
	</div>
</div>

<div class="mt-3">
	<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
	<a asp-action="Index" class="btn btn-secondary">Back</a>
</div>